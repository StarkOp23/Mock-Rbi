# =============================================================================
# Mock RBI CMS Portal — environment template
# Copy to .env and fill in. NEVER commit a real .env file.
# =============================================================================

# --- Postgres ---
POSTGRES_DB=rbi_cms
POSTGRES_USER=rbi_user
POSTGRES_PASSWORD=rbi_pass_demo_only

# --- API auth (the token banks/agents present when calling the mock RBI API) ---
# The browser UI uses this same token (injected by nginx). Keep them in sync.
RBI_API_KEY=rbi_demo_token_change_me

# --- Bank-side Crest endpoint ---
# When sharing Crest's docker network, address Crest by container name:
CREST_BANK_BASE_URL=http://crestai_backend:8000
CREST_BANK_API_KEY=crest_test_sk_<paste_your_real_key_from_Crest_Settings>
CREST_BANK_AGENT_ID=<paste_your_agent_uuid_from_Crest_URL>

# --- Crest's docker network name ---
# Find with: docker network ls | findstr crest
CREST_NETWORK=crest-platform_crestai_net

# --- Logging ---
LOG_LEVEL=INFO
