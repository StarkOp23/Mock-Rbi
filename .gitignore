# =============================================================================
# Mock RBI CMS — .gitignore
# Covers: Python (FastAPI backend), Node/Vite (React frontend),
#         Docker, secrets, editors, OS cruft
# =============================================================================

# ---- Secrets & local config -------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# Keep the template
!.env.example

# ---- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
.Python
build/
develop-eggs/
dist/
downloads/
sdist/
wheels/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# ---- Node / frontend --------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnpm-store/
.yarn/

# Vite / build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
*.local

# ---- Docker -----------------------------------------------------------------
# Local compose override (commonly used for dev tweaks)
docker-compose.override.yml
docker-compose.override.yaml

# ---- Databases / data -------------------------------------------------------
*.sqlite
*.sqlite3
*.db
pgdata/
postgres-data/

# ---- Logs -------------------------------------------------------------------
*.log
logs/

# ---- Editors / IDEs ---------------------------------------------------------
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# ---- OS ---------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Misc -------------------------------------------------------------------
*.tmp
*.bak
*.orig
.cache/